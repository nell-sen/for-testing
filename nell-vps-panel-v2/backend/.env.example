# ──────────────────────────────────────────────────────────────
# NELL VPS PANEL v2.0 — Backend Configuration
# ──────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── Auth (JWT) ────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-very-long-random-string
JWT_REFRESH_SECRET=change-me-refresh-secret-very-long-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── CORS (comma separated) ────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Bot execution ─────────────────────────────────────────────
# "docker" (preferred, sandboxed) or "child_process" (fallback)
EXECUTION_MODE=docker
DOCKER_IMAGE=node:20-alpine
DOCKER_MEMORY_LIMIT=256m
DOCKER_CPU_LIMIT=0.5
DOCKER_NETWORK=bridge

# ── Per-user usage limits ─────────────────────────────────────
LIMIT_BOTS_PER_USER=5
LIMIT_CPU_PER_BOT=0.5
LIMIT_MEM_PER_BOT_MB=256
LIMIT_FILE_UPLOAD_MB=50

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
DEBUG=false
